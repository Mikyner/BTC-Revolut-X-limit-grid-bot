# ============================================================
# BTC/EUR Limit Order Grid Bot — konfigurace
# Zkopíruj tento soubor jako `.env` a vyplň vlastní hodnoty.
# Soubor `.env` se NIKDY necommituje do gitu (viz .gitignore).
# ============================================================

# --- Režim provozu ---
# true  = paper trading (simulace, žádné skutečné peníze)
# false = live obchodování na Revolut X (POUŽÍVEJ AŽ PO DŮKLADNÉM OTESTOVÁNÍ)
DRY_RUN=true

# --- Revolut X API ---
# Vygeneruj API klíč v Revolut X aplikaci (Settings → API)
# a privátní klíč přes `python generate_revolutx_keys.py`
REVOLUTX_API_KEY=
REVOLUTX_PRIVATE_KEY_PATH=/app/data/revolutx_private.pem

# --- Obchodní pár ---
TRADING_PAIR=BTC-EUR

# --- Parametry mřížky ---
# GRID_LEVELS: počet cenových úrovní v mřížce (více = jemnější krok, víc obchodů)
# GRID_RANGE_PERCENT: celkový rozsah mřížky kolem aktuální ceny (%)
# GRID_BIAS_PERCENT: asymetrie mřížky — kladná hodnota = víc úrovní POD cenou
#   (např. 35 = 65 % mřížky je pod aktuální cenou, 35 % nad ní)
GRID_LEVELS=41
GRID_RANGE_PERCENT=25
GRID_BIAS_PERCENT=35

# --- Velikost pozice ---
ORDER_SIZE_EUR=10
PAPER_STARTING_BALANCE_EUR=350

# --- Risk management ---
# Pokud cena vyletí mimo mřížku o víc než tato hodnota (%), bot se pozastaví
# a čeká na ruční re-center (tlačítko v dashboardu).
MAX_PRICE_DEVIATION_PERCENT=25

# --- Interval kontrol (sekundy) ---
# Jak často bot kontroluje vyplněné ordery a synchronizuje se s burzou.
# Pro limit ordery stačí 30-60s (na rozdíl od market botů není potřeba sub-minutová reakce).
POLL_INTERVAL_SECONDS=60

# --- Flask web dashboard ---
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_PORT=5051

# --- Telegram notifikace (volitelné) ---
# Vytvoř bota přes @BotFather, ID chatu zjistíš přes @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_TRADES=true
TELEGRAM_NOTIFY_PAUSE=true
TELEGRAM_NOTIFY_DAILY_SUMMARY=true
TELEGRAM_DAILY_SUMMARY_TIME=20:00
TELEGRAM_PAUSE_REMINDER_MINUTES=60
